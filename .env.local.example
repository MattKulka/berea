# Supabase project settings (Project Settings -> Data API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service_role key -- used only by local scripts (ingestion, embeddings,
# demo-user helpers). Never imported by client code or shipped to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string (Supabase dashboard -> Connect -> Direct connection).
# Only needed for scripts/build-hnsw-index.ts, which requires a longer-running
# connection than the Supabase SQL Editor allows.
DATABASE_URL=

# Anthropic API key -- server-side only (api/ask.ts, server/dev-api.ts)
ANTHROPIC_API_KEY=

# Voyage AI API key -- server-side only (scripts/generate-embeddings.ts)
VOYAGE_API_KEY=
